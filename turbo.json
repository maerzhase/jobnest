{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "api:generate": {
      "cache": true,
      "outputs": ["src/lib/api/bindings.ts"]
    },
    "build": {
      "dependsOn": ["^build", "api:generate"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build", "api:generate"]
    },
    "dev:tauri": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "cache": true,
      "outputs": []
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "cache": true,
      "outputs": []
    },
    "format:fix": {
      "cache": false
    },
    "typecheck": {
      "cache": true,
      "dependsOn": ["^build", "api:generate"],
      "outputs": []
    }
  }
}
