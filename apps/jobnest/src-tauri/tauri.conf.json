{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jobnest",
  "version": "0.1.0",
  "identifier": "com.m3000.jobnest",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "jobnest",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "dialog": {
      "allow-ask": true,
      "allow-message": true,
      "allow-save": true,
      "allow-open": true
    },
    "fs": {
      "allow-read": true,
      "allow-write": true,
      "allow-mkdir": true,
      "allow-remove": true,
      "allow-rename": true,
      "allow-exists": true,
      "allow-copy-file": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
