{
  "name": "@jobnest/ui",
  "description": "Opinionated Base UI + Tailwind component package for the monorepo template.",
  "version": "0.0.0",
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@storybook/addon-a11y": "10.1.2",
    "@storybook/addon-docs": "10.1.2",
    "@storybook/addon-themes": "10.1.2",
    "@storybook/react": "10.1.2",
    "@storybook/react-vite": "10.1.2",
    "@tailwindcss/cli": "4.2.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.14.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "10.1.2",
    "tailwindcss": "4.2.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.2",
    "vite-tsconfig-paths": "5.1.4"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css",
    "./theme.css": "./theme.css"
  },
  "files": [
    "dist",
    "styles.css",
    "theme.css",
    "src/styles"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "peerDependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tailwindcss -i src/styles/styles.css -o dist/styles.css --minify",
    "build-storybook": "storybook build",
    "dev": "tsdown --watch",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "storybook": "storybook dev -p 6007",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "types": "./dist/index.d.ts"
}
